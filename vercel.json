{
  "version": 2,
  "buildCommand": "cd react-frontend && npm install && npm run build",
  "outputDirectory": "react-frontend/dist",
  "framework": "vite",
  "functions": {
    "api/index.py": {
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
